---
export interface Props {
  title: string;
}
const { title } = Astro.props as Props;
---
<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content="科技/IT与相关财经新闻自动聚合站，每小时更新，数据来源为公开免费RSS。" />
    <link rel="icon" href={`${import.meta.env.BASE_URL}favicon.svg`} />
  </head>
  <body>
    <header class="site-header">
      <div class="wrap">
        <a class="brand" href={import.meta.env.BASE_URL}>科技新闻速览</a>
        <nav>
          <a href={import.meta.env.BASE_URL}>全部</a>
          <a href={`${import.meta.env.BASE_URL}category/tech/`}>科技/IT</a>
          <a href={`${import.meta.env.BASE_URL}category/finance/`}>相关财经</a>
        </nav>
      </div>
    </header>
    <main class="wrap">
      <slot />
    </main>
    <footer class="wrap">
      <p>
        本站为个人自动聚合项目，内容版权归原作者/媒体所有，点击标题跳转原文阅读。
        数据每小时由 GitHub Actions 自动抓取公开 RSS 源更新。
      </p>
    </footer>
  </body>
</html>

<style is:global>
  :root {
    color-scheme: light dark;
    --fg: #1a1a1a;
    --bg: #ffffff;
    --muted: #666;
    --border: #e5e5e5;
    --accent: #2563eb;
  }
  @media (prefers-color-scheme: dark) {
    :root {
      --fg: #e5e5e5;
      --bg: #0f0f10;
      --muted: #999;
      --border: #2a2a2a;
      --accent: #60a5fa;
    }
  }
  * { box-sizing: border-box; }
  body {
    margin: 0;
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", "PingFang SC", "Microsoft YaHei", sans-serif;
    color: var(--fg);
    background: var(--bg);
    line-height: 1.6;
  }
  .wrap { max-width: 860px; margin: 0 auto; padding: 0 16px; }
  .site-header {
    border-bottom: 1px solid var(--border);
    padding: 14px 0;
  }
  .site-header .wrap {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 8px;
  }
  .brand { font-weight: 700; font-size: 1.15rem; color: var(--fg); text-decoration: none; }
  nav a {
    margin-left: 16px;
    color: var(--muted);
    text-decoration: none;
    font-size: 0.95rem;
  }
  nav a:hover { color: var(--accent); }
  main { padding: 24px 16px 40px; }
  footer {
    border-top: 1px solid var(--border);
    color: var(--muted);
    font-size: 0.82rem;
    padding: 16px;
  }
</style>
